# ============================================================
# Maré — Variáveis de Ambiente
# ============================================================
# Copie este arquivo como .env e preencha os valores:
#   cp .env.example .env
# ============================================================

# --- Push Notifications (Cloudflare Worker) ---
# URL do Worker de notificações (sem barra no final)
# Ex: https://mare-push-worker.seu-subdominio.workers.dev
VITE_WORKER_URL=

# Chave pública VAPID para Web Push (formato Base64URL)
# Gerar com: npx web-push generate-vapid-keys
# Cole APENAS a chave pública (sem aspas)
VITE_VAPID_PUBLIC_KEY=
